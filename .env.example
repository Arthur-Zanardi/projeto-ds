# =====================================================================
# MatchAI — exemplo de variáveis de ambiente.
# Copie para `.env` e preencha com valores reais. NUNCA versione `.env`.
# =====================================================================

# Ambiente: "dev" ou "prod". Em "prod" as variáveis obrigatórias
# (DATABASE_URL, JWT_SECRET, GROQ_API_KEY) precisam estar definidas.
ENV=dev

# --- Banco de dados (PostgreSQL + pgvector) ---
# Formato SQLAlchemy/psycopg 3: postgresql+psycopg://usuario:senha@host:porta/banco
DATABASE_URL=postgresql+psycopg://matchai:matchai@localhost:5432/matchai

# --- Autenticação JWT ---
# Gere um segredo forte, ex.: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-forte
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Integração LLM (Groq) ---
GROQ_API_KEY=coloque-sua-chave-groq-aqui

# --- Frontend (Flet) ---
# URL base onde o frontend encontra a API.
MATCHAI_API_BASE_URL=http://127.0.0.1:8000

# --- CORS ---
# Origens permitidas, separadas por vírgula. Use "*" apenas em dev.
CORS_ALLOW_ORIGINS=http://localhost:8550,http://127.0.0.1:8550

# --- Administradores ---
# E-mails com privilégio de admin, separados por vírgula.
ADMIN_EMAILS=

# --- Seed automático (apenas dev) ---
# Quando "true" e ENV=dev, popula perfis mock no startup.
SEED_ON_STARTUP=true
